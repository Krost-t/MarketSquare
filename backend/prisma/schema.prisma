  // ─── Product ─────────────────────────────────────────────

  model Product {
    id          String   @id @default(uuid()) @db.Uuid
    name        String
    description String?
    price       Decimal  @db.Decimal(10, 2)
    stock       Int      @default(0)
    imageUrl    String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

