// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ========== Enums ==========

enum Role {
  MERCHANT
  ADMIN
  USER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
  SHOP
}

enum HousingType {
  HOUSE
  APARTMENT
  STUDIO
  OFFICE
  OTHER
}

enum OrderStatus {
  PENDING    // commande créée, paiement attendu
  PAID       // paiement validé
  PREPARING  // préparation par le vendeur
  SHIPPED    // expédiée
  DELIVERED  // livrée
  CANCELLED  // annulée avant expédition
  RETURNED   // retournée par le client après livraison
}

enum PaymentMethod {
  CARD
  PAYPAL
  BANK_TRANSFER
}


// ========== User ===========
model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  username    String   @unique
  password    String
  lastname    String
  firstname   String
  dateOfBirth DateTime @db.Date
  gender      Gender
  phone       String
  role        Role @default(USER)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addresses Address[]
  reviews   Review[]
  shop      Shop?
  cart      Cart?
  orders    Order[]
}

// ========== Address ===========
model Address {
  id          String      @id @default(uuid()) @db.Uuid
  type        AddressType @default(SHIPPING)
  housingType HousingType @default(HOUSE)

  streetAddress  String // n° + nom de rue
  postalCode     String
  addressRegion  String // département
  addressCountry String @db.Char(2) // ISO 3166-1 alpha-2 ("FR", "BE", "US")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopId String? @unique @db.Uuid
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========== Shop ===========
model Shop {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  imageUrl    String?

  averageRating Decimal @default(0) @db.Decimal(2, 1)
  reviewCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchantId String @unique @db.Uuid
  merchant   User   @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  address  Address?
  products Product[]
  reviews  Review[]
}

//  ========== Product  ===========
model Product {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  stock       Int     @default(0)
  imageUrl    String?
  isActive    Boolean @default(true)

  averageRating Decimal @default(0) @db.Decimal(2, 1)
  reviewCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews    Review[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  shopId String @db.Uuid
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ========== Review ===========
model Review {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Decimal  @db.Decimal(2, 1)
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  shopId String? @db.Uuid
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([authorId, productId])
  @@unique([authorId, shopId])
  @@index([productId])
  @@index([shopId])
}

// ========== Cart ===========
model Cart {
  id String @id @default(uuid()) @db.Uuid

  customerId String @unique @db.Uuid
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== CartItem ===========
model CartItem {
  id       String @id @default(uuid()) @db.Uuid
  quantity Int

  cartId String @db.Uuid
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

// ========== Order ===========
model Order {
  id            String        @id @default(uuid()) @db.Uuid
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  totalAmount   Decimal       @db.Decimal(10, 2)

  // Snapshot de l'adresse de livraison (immuable une fois la commande créée)
  shippingStreet     String
  shippingPostalCode String
  shippingRegion     String
  shippingCountry    String @db.Char(2)

  customerId String @db.Uuid
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Restrict)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

// ========== OrderItem ===========
model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) // snapshot du prix au moment de la commande

  orderId String @db.Uuid
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

