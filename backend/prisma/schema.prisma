  // ========== User ===========
  model User {
    id        String   @id @default(uuid()) @db.Uuid
    email     String   @unique
    password  String
    firstname String
    surname   String
    role      Role     @default(CUSTOMER)
    avatarUrl String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

